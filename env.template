# Copy to .env for local use. Plexify is stateless — this is only bootstrap config, not data kept between runs.
#
# music-social instance (HTTPS base URL, no trailing slash required)
MUSIC_SOCIAL_URL=https://your-music-social.example.com
# MUSIC_SOCIAL_USERNAME lists all public playlists for that user
MUSIC_SOCIAL_USERNAME=
# Optional comma-separated playlist IDs (can combine with username)
MUSIC_SOCIAL_PLAYLIST_ID=
# Optional comma-separated playlist IDs to exclude from processing
MUSIC_SOCIAL_PLAYLIST_EXCLUDED_ID=

# Plex
PLEX_URL=http://your_plex_server:32400
PLEX_TOKEN=your_plex_token_here
PLEX_LIBRARY_SECTION_ID=your_music_library_section_id
# Leave empty to auto-discover, or set manually if auto-discovery fails
PLEX_SERVER_ID=

# Plex HTTPS: by default certificate verification is skipped (typical LAN / self-signed). Enable strict checks:
# PLEX_VERIFY_TLS=true
# Optional explicit insecure (redundant with default): PLEX_INSECURE_SKIP_VERIFY=true
# Force verify if you had set insecure: PLEX_INSECURE_SKIP_VERIFY=false

# Optional: parallel Plex track lookups (1 = sequential, max 32)
# PLEX_MATCH_CONCURRENCY=4

# Plex HTTP rate limit (requests per second, token bucket burst 1). Default 4; 0 = unlimited
# PLEX_MAX_REQUESTS_PER_SECOND=8

# Dry-run: match + diff only; no playlist create/clear/add on Plex
# PLEXIFY_DRY_RUN=true
# (or: DRY_RUN=true)

# Fast search: skip expensive full-library scan (/library/sections/{id}/all); indexed /search only
# PLEXIFY_FAST_SEARCH=true
# (alias: PLEX_SKIP_FULL_LIBRARY_SEARCH=true)

# Exact-matches-only: only first Plex search strategy (source title/artist as-is); skips normalizations + full-library scan (faster gap-finding)
# PLEXIFY_EXACT_MATCHES_ONLY=true

# At least one of MUSIC_SOCIAL_USERNAME or MUSIC_SOCIAL_PLAYLIST_ID must be set.
# Unlisted playlists are not listed by username; pass their id explicitly in MUSIC_SOCIAL_PLAYLIST_ID.
