# Copy to .env for local use. Plexify is stateless — this is only bootstrap config, not data kept between runs.
# Load order: OS environment → .env (optional) → CLI flags. See README "Environment variable reference".

# =============================================================================
# Required
# =============================================================================

# music-social.com API base (default matches Plexify; override for self-hosted / compatible host).
# You may omit this line entirely — the binary defaults to https://music-social.com.
MUSIC_SOCIAL_URL=https://music-social.com

# Plex
PLEX_URL=http://your_plex_server:32400
PLEX_TOKEN=your_plex_token_here
PLEX_LIBRARY_SECTION_ID=your_music_library_section_id

# At least one of MUSIC_SOCIAL_USERNAME or MUSIC_SOCIAL_PLAYLIST_ID must be set.
# MUSIC_SOCIAL_USERNAME lists all public playlists for that user.
MUSIC_SOCIAL_USERNAME=
# Optional comma-separated playlist IDs (can combine with username)
MUSIC_SOCIAL_PLAYLIST_ID=

# =============================================================================
# Optional — defaults shown (omit a line to use the same built-in default)
# =============================================================================

# Optional comma-separated playlist IDs to exclude from processing
MUSIC_SOCIAL_PLAYLIST_EXCLUDED_ID=

# Leave empty to auto-discover, or set manually if auto-discovery fails
PLEX_SERVER_ID=

# Parallel Plex track lookups during matching (clamped 1–32)
PLEX_MATCH_CONCURRENCY=1

# Max Plex HTTP requests per second (token bucket, burst 1). 0 = unlimited
PLEX_MAX_REQUESTS_PER_SECOND=4

# Minimum combined match score to accept a Plex track (integer 0–100, optional trailing %)
PLEXIFY_MATCH_CONFIDENCE_PERCENT=80

# =============================================================================
# Optional booleans — default off (set to true / 1 / yes / on to enable)
# =============================================================================

# Match + diff only; no playlist create/clear/add on Plex
# PLEXIFY_DRY_RUN=true
# (alias)
# DRY_RUN=true

# Skip full-library scan; use Plex /search only
# PLEXIFY_FAST_SEARCH=true
# (alias)
# PLEX_SKIP_FULL_LIBRARY_SEARCH=true

# Only raw title/artist search; no normalizations or full-library scan
# PLEXIFY_EXACT_MATCHES_ONLY=true

# =============================================================================
# Plex HTTPS / TLS
# Default when PLEX_INSECURE_SKIP_VERIFY is unset: skip certificate verification (typical LAN / self-signed).
# If PLEX_INSECURE_SKIP_VERIFY is set: truthy = skip verify, falsy = verify.
# PLEX_VERIFY_TLS=true forces verification and wins over insecure defaults.
# =============================================================================

# PLEX_VERIFY_TLS=true
# PLEX_INSECURE_SKIP_VERIFY=false

# =============================================================================
# Output
# Any non-empty value disables ANSI colors in playlist diff when stdout is a TTY
# =============================================================================

# NO_COLOR=1

# =============================================================================
# Notes
# Unlisted playlists are not returned by username listing; pass their id in MUSIC_SOCIAL_PLAYLIST_ID.
# =============================================================================
